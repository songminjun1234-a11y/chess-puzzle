generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())

  solvedPuzzles SolvedPuzzle[]
  folders       Folder[]
  solveLogs     SolveLog[]
  bugReports    BugReport[]
  puzzleReviews PuzzleReview[]
}

model Folder {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())

  user    User            @relation(fields: [userId], references: [id])
  puzzles FolderPuzzle[]
}

model FolderPuzzle {
  id        String   @id @default(cuid())
  folderId  String
  puzzleId  String
  createdAt DateTime @default(now())

  folder Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  puzzle Puzzle @relation(fields: [puzzleId], references: [id], onDelete: Cascade)

  @@unique([folderId, puzzleId])
}

model Puzzle {
  id          String   @id @default(cuid())
  fen         String
  moves       String
  difficulty  String
  rating      Int?
  category    String   @default("fork")
  mateIn      String?
  themes      String?
  title       String
  // Human-written commentary on why the solution is best, shown alongside
  // the engine's evaluation in the wrong-answer feedback panel.
  explanation String?
  createdAt   DateTime @default(now())

  solvedPuzzles SolvedPuzzle[]
  folderPuzzles FolderPuzzle[]
  solveLogs     SolveLog[]
  bugReports    BugReport[]
  puzzleReviews PuzzleReview[]
}

model SolvedPuzzle {
  id        String   @id @default(cuid())
  userId    String
  puzzleId  String
  solvedAt  DateTime @default(now())
  attempts  Int      @default(1)

  user   User   @relation(fields: [userId], references: [id])
  puzzle Puzzle @relation(fields: [puzzleId], references: [id])

  @@unique([userId, puzzleId])
}

// One row per completed solve, preserved across repeat attempts (unlike
// SolvedPuzzle, which is upserted) so "기보 다시보기" has real history.
model SolveLog {
  id          String   @id @default(cuid())
  userId      String
  puzzleId    String
  attempts    Int      @default(1)
  timeSeconds Int?
  solvedAt    DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  puzzle Puzzle @relation(fields: [puzzleId], references: [id])

  @@index([userId, solvedAt])
}

// SM-2-style spaced-repetition state, one row per user+puzzle. Updated each
// time a puzzle is solved so the "약점 복습" queue can resurface puzzles at
// the right time — soon after a struggle, later and later after clean solves —
// instead of just re-showing every puzzle in a weak theme every time.
model PuzzleReview {
  id             String    @id @default(cuid())
  userId         String
  puzzleId       String
  easeFactor     Float     @default(2.5)
  intervalDays   Int       @default(0)
  repetitions    Int       @default(0)
  dueAt          DateTime  @default(now())
  lastReviewedAt DateTime?
  createdAt      DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id])
  puzzle Puzzle @relation(fields: [puzzleId], references: [id])

  @@unique([userId, puzzleId])
  @@index([userId, dueAt])
}

model BugReport {
  id        String   @id @default(cuid())
  userId    String?
  puzzleId  String?
  message   String
  pageUrl   String?
  status    String   @default("open") // "open" | "resolved"
  createdAt DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  puzzle Puzzle? @relation(fields: [puzzleId], references: [id])

  @@index([status, createdAt])
}
